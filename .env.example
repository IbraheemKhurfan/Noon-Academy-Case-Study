# Copy this file to .env and adjust as needed. `make demo` does this for you
# automatically if .env does not already exist. Never commit a real .env.

# --- Paths -------------------------------------------------------------
DATA_DIR=./data
OUTPUT_DIR=./outputs
DATABASE_URL=sqlite:///./boon.db

# --- Case-study clock ----------------------------------------------------
# Today is Day 14. Quiz 1 happened Day 10. Quiz 2 is Day 20 (6 days remain).
AS_OF_DATE=2025-10-14
QUIZ1_DATE=2025-10-10
QUIZ2_DATE=2025-10-20

# --- LLM (OpenAI SDK — works against any OpenAI-compatible endpoint) -----
# The full non-LLM pipeline and app work with LLM_ENABLED=false or a missing key.
LLM_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Leave blank for real OpenAI. Set to use a compatible provider instead, e.g.
# Groq: OPENAI_BASE_URL=https://api.groq.com/openai/v1, OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=

# --- App -----------------------------------------------------------------
APP_PORT=8501
# dry_run = messages are simulated and saved to the outbox, never sent for real.
NOTIFICATION_MODE=dry_run

# --- Demo login seed (used only to create accounts on first run) --------
SEED_ADMIN_EMAIL=admin@boonacademy.demo
SEED_ADMIN_PASSWORD=Admin@2025
SEED_FACILITATOR_PASSWORD=Coach@2025
