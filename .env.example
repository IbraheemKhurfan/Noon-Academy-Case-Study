# Copy this file to .env and fill in values as needed.
# main.py / app.py read all configuration from environment variables — see src/config.py.

# Input CSVs: student_daily_metrics.csv, facilitator_notes.csv, student_metadata.csv
DATA_DIR=./data

# Where the pipeline writes roster/worklist/dashboard files
OUTPUT_DIR=./outputs

# Set to false to force deterministic template fallback (no network calls)
LLM_ENABLED=true

# Required only when LLM_ENABLED=true. Never commit a real key.
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini

# Port used by `streamlit run app.py`
APP_PORT=8501
